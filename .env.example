# ─────────────────────────────────────────────────────────────────────────────
# Odoo connection — copy this file to .env and fill in your values
# These are read SERVER-SIDE only (Vercel function / Vite dev proxy).
# They are NEVER exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Odoo instance URL (no trailing slash)
VITE_ODOO_URL=https://your-instance.odoo.com

# Database name — same as the subdomain
VITE_ODOO_DB=your-instance

# Login email of the Odoo user
VITE_ODOO_LOGIN=your.email@company.com

# Authentication — use ONE of the following:
# Option A (recommended): API key — generate in Odoo → Settings → Technical → API Keys
VITE_ODOO_API_KEY=your_odoo_api_key_here
# Option B: Account password
# VITE_ODOO_PASSWORD=your_odoo_password_here
